a = int(input("enter amount of rooms:  "))
b = list(map(int, input("enter numbers:  ").split()))
zigzag = True
for i in range (1, a - 1):
    if (b[i] > b[i-1] and b[i] > b[i+1]) or (b[i] < b[i-1] and b[i] < b[i+1]):
        continue
    else:
        zigzag = False
        break
if zigzag:
    print("YES")
else:
    print("NO")
